{
  "name": "git-released",
  "version": "0.1.5",
  "description": "Find the first release containing a git commit — CLI. (Published as `git-released` because the unscoped `released` name on npm was taken in 2014.)",
  "keywords": [
    "git",
    "release",
    "tag",
    "version",
    "github",
    "gitlab",
    "first-release",
    "since-release",
    "cli"
  ],
  "homepage": "https://released.blabberate.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukaso/released.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lukaso/released/issues"
  },
  "license": "MIT",
  "author": "Lukas Oberhuber <lukas@hiphops.io>",
  "type": "module",
  "bin": {
    "released": "./dist/cli.js",
    "git-released": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --out-dir dist --clean --shims",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "micromark": "^4.0.1"
  },
  "devDependencies": {
    "@released/core": "workspace:*",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "released",
  "version": "0.0.0",
  "description": "Find the first release containing a git commit — CLI.",
  "type": "module",
  "bin": {
    "released": "./dist/cli.js",
    "git-released": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --out-dir dist --clean --shims",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@released/core": "workspace:*",
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" }
}

# Pin the default registry to public npm.
#
# Without this, Dependabot's npm/pnpm updater fails every run. Its
# `automatic-github-packages-auth` experiment injects a GitHub Packages
# credential, which makes corepack-pnpm resolve EVERY dependency against
# https://npm.pkg.github.com/ — a stale mirror that only serves old versions
# (e.g. @types/jsdom maxes at 16.2.14, @types/node at 17.0.18). Our manifests
# pin newer ranges (@types/jsdom ^21.1.7, @types/node ^22.10.2), so resolution
# dies with ERR_PNPM_NO_MATCHING_VERSION and no update PRs ever open.
#
# Setting the default registry explicitly overrides that injected default, so
# Dependabot (and any fresh checkout) resolves from public npm. All our deps are
# public; nothing here is hosted on GitHub Packages. Local/CI installs are
# unaffected — this is already npm's default.
registry=https://registry.npmjs.org/

#!/usr/bin/env bash
# Pre-commit: lint staged JS/TS/JSON files with biome. Fast (~tens of ms).
# Mirrors the Lint step in .github/workflows/ci.yml so CI never fails on
# something a local commit could have caught.
#
# Skip for WIP commits with: `git commit --no-verify`
#
# Written for macOS's bundled bash 3.2 + BSD grep — no mapfile, no -z flag,
# no process substitution into arrays.
set -euo pipefail

# Skip in CI. GitHub Actions sets CI=true. The Changesets action's auto-
# commit (chore(release): version packages) regenerates package.json
# files via a JSON serializer that doesn't match biome's formatter
# exactly, and the workflow already runs `pnpm lint` as a separate step
# anyway.
if [ -n "${CI:-}" ]; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel)" || exit 1

# Secret scan FIRST, on all staged files (not just JS) — a stray `git add` of a
# .dev.vars / .env is the highest-blast-radius mistake. Blocks the commit if a
# token/key is staged; no-ops if gitleaks isn't installed (CI is the gate).
scripts/secrets-scan.sh --staged

# Newline-separated list of staged files. --diff-filter=ACM = Added, Copied,
# Modified (skips Deletions, which can't be linted). Filenames with embedded
# newlines aren't a realistic concern in a TS project; if they ever are,
# rewrite this to use `git diff -z` + a portable null-delimited loop.
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|json|jsonc)$' || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

# biome check = formatter + linter + import organizer in one pass.
# Intentional word-splitting on STAGED.
# shellcheck disable=SC2086
pnpm exec biome check $STAGED
